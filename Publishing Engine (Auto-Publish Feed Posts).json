    {
      "parameters": {
        "jsCode": "const item=$('Publish Loop').first().json;\nif(item.empty)return[{json:{skipped:true}}];\nconst sd=$getWorkflowStaticData('global');\nconst pub=$('Publish Post').first().json;\nsd.pubResults.push({postId:item.postId,contentType:item.contentType,igPostId:pub.id||'',success:!!pub.id});\nreturn[{json:{postId:item.postId,igPostId:pub.id}}];"
      },
      "id": "06803871-418b-4975-b718-9f79f14ae96a",
      "name": "Track Publish",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3296,
        1008
      ]
    },
    {
      "parameters": {
        "jsCode": "const sd=$getWorkflowStaticData('global');\nconst results=sd.pubResults||[];\nconst todayStr=new Date().toISOString().split('T')[0];\nconst cal=$('Read Calendar').all().map(i=>i.json);\nconst stories=cal.filter(p=>p.ContentType==='story'&&p.ScheduledDate===todayStr);\nconst ok=results.filter(r=>r.success).length;\nconst total=results.length;\nconst lines=results.map(r=>(r.success?'✅':'❌')+' '+r.contentType+': '+r.postId);\nconst storyInfo=stories.length?'\\n📱 '+stories.length+' stories due today - check reminders':'';\nconst msg='📤 *Publishing Report*\\n'+lines.join('\\n')+storyInfo;\nconst updates=[];\nresults.forEach(r=>{\n  if(r.success)updates.push({PostID:r.postId,Status:'published',Already_Published:'true',Published_At:new Date().toISOString(),Instagram_Post_ID:r.igPostId});\n});\nreturn[{json:{msg,updates,stories,total,ok,failed:total-ok,date:todayStr,ts:new Date().toISOString()}}];"
      },

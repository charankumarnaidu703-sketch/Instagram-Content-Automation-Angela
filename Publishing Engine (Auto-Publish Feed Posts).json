    {
      "parameters": {
        "jsCode": "const d = $('Filter & Validate').first().json;\nconst due    = d.due    || [];\nconst slides = d.slides || [];\nconst results = [];\n\nfor (const p of due) {\n  const contentType = (p.ContentType || '').toUpperCase().trim();\n\n  // ════ CAROUSEL ════\n  if (contentType === 'CAROUSEL') {\n    const postSlides = slides.filter(s => s.postId === p.PostID);\n    if (postSlides.length) {\n      postSlides.forEach(x => results.push({\n        json: {\n          postId:        p.PostID,\n          contentType:   p.ContentType,\n          media_type:    'IMAGE',\n          image_url:     x.slideUrl || x.renderUrl || x.image_url || '',\n          caption:       p.Caption   || '',\n          hashtags:      p.Hashtags  || '',\n          slideNum:      x.slideNum  || x.num || '',\n          totalSlides:   postSlides.length,\n          scheduledDate: p.ScheduledDate,\n          scheduledTime: p.ScheduledTime\n        }\n      }));\n    } else {\n      results.push({ json: { skip: true, postId: p.PostID, reason: 'No slides found for carousel' } });\n    }\n  }\n\n  // ════ SINGLE IMAGE ════\n  else if (contentType === 'SINGLE IMAGE') {\n    results.push({\n      json: {\n        postId:        p.PostID,\n        contentType:   p.ContentType,\n        media_type:    'IMAGE',\n        image_url:     p.Visual_URL || '',\n        caption:       p.Caption    || '',\n        hashtags:      p.Hashtags   || '',\n        scheduledDate: p.ScheduledDate,\n        scheduledTime: p.ScheduledTime\n      }\n    });\n  }\n\n  // ════ REEL / VIDEO ════\n  else if (contentType === 'REEL' || contentType === 'VIDEO') {\n    results.push({\n      json: {\n        postId:        p.PostID,\n        contentType:   p.ContentType,\n        media_type:    'REELS',\n        video_url:     p.Visual_URL || '',\n        caption:       p.Caption    || '',\n        hashtags:      p.Hashtags   || '',\n        share_to_feed: true,\n        scheduledDate: p.ScheduledDate,\n        scheduledTime: p.ScheduledTime\n      }\n    });\n  }\n\n  // ════ STORY ════\n  else if (contentType === 'STORY') {\n    results.push({\n      json: {\n        postId:        p.PostID,\n        contentType:   p.ContentType,\n        media_type:    'STORIES',\n        image_url:     p.Visual_URL  || p.Render_URL || '',\n        video_url:     p.video_url   || '',\n        caption:       p.Caption     || '',\n        hashtags:      p.Hashtags    || '',\n        storyType:     p.StoryType   || '',\n        mainText:      p.MainText    || '',\n        supportText:   p.SupportText || '',\n        interactiveElement: p.InteractiveElement || '',\n        scheduledDate: p.ScheduledDate,\n        scheduledTime: p.ScheduledTime\n      }\n    });\n  }\n\n  // ════ UNKNOWN — skip ════\n  else {\n    results.push({\n      json: {\n        skip:        true,\n        postId:      p.PostID,\n        contentType: p.ContentType,\n        reason:      'Unknown content type — no handler defined'\n      }\n    });\n  }\n}\n\nreturn results.length ? results : [{ json: { skip: true } }];"
      },

    {
      "parameters": {
        "jsCode": "const d=$input.first().json;\nif(d.skip)return[{json:{skipped:true}}];\nconst sd=$getWorkflowStaticData('global');\nconst pid=$('Slide Loop').first().json.postId;\nconst cid=$('Create Slide Container').first().json.id;\nif(!sd.slideIds[pid])sd.slideIds[pid]=[];\nsd.slideIds[pid].push(cid);\nreturn[{json:{postId:pid,slideId:cid}}];"
      },
      "id": "b918fc6b-27ca-4bbb-be7b-4424638b4e31",
      "name": "Track Slide",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2912,
        768
      ]
    },
    {
      "parameters": {
        "jsCode": "const item        = $input.first().json;\nconst tok         = $('Filter & Validate').first().json.tok;\nconst contentType = (item.contentType || '').toUpperCase().trim();\n\nconst hashtags    = (item.hashtags || '').trim();\nconst captionOnly = (item.caption  || '').trim();\nconst fullCaption = hashtags\n  ? `${captionOnly}\\n\\n${hashtags}`\n  : captionOnly;\n\nlet body = {};\n\n// ════ SINGLE IMAGE ════\nif (contentType === 'SINGLE IMAGE') {\n  body = {\n    image_url:    item.image_url,\n    caption:      fullCaption,\n    access_token: tok\n  };\n}\n// ════ CAROUSEL SLIDE ════\nelse if (contentType === 'CAROUSEL') {\n  body = {\n    image_url:        item.image_url,\n    is_carousel_item: true,\n    access_token:     tok\n  };\n}\n// ════ REEL / VIDEO ════\nelse if (contentType === 'REEL' || contentType === 'VIDEO') {\n  body = {\n    media_type:    'REELS',\n    video_url:     item.video_url,\n    caption:       fullCaption,\n    share_to_feed: true,\n    access_token:  tok\n  };\n}\n// ════ STORY ════✅\n// ════ STORY ════\nelse if (contentType === 'STORY') {\n  // ✅ FIX: story rows store the URL in Visual_URL or Render_URL, not image_url\n  const storyImageUrl = item.image_url\n    || item.Visual_URL\n    || item.Render_URL\n    || '';\n\n  if (item.video_url) {\n    body = {\n      media_type:   'STORIES',\n      video_url:    item.video_url,\n      access_token: tok\n    };\n  } else {\n    body = {\n      media_type:   'STORIES',\n      image_url:    storyImageUrl,\n      access_token: tok\n    };\n  }\n}\n\nreturn [{\n  json: {\n    body:        JSON.stringify(body),\n    postId:      item.postId      || item.PostID,\n    contentType: item.contentType,\n    fullCaption: fullCaption\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",

      },
      "id": "de659f7e-d66b-4dd5-9d86-31de16de2897",
      "name": "Wait Slide",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        2624,
        768
      ],
      "webhookId": "256d3aea-95d4-41f8-9314-27e10a3b1922"
    },
    {
      "parameters": {
        "jsCode": "const fv  = $('Filter & Validate').first().json;\nconst sd  = $getWorkflowStaticData('global');\nconst due = fv.due || [];\nconst tok = fv.tok;\nconst aid = fv.aid;\n\nconst q = [];\n\ndue.forEach(p => {\n  const cap         = (p.Caption  || '').trim() + '\\n\\n' + (p.Hashtags || '').trim();\n  const contentType = (p.ContentType || '').toUpperCase().trim();\n\n  if (contentType === 'SINGLE IMAGE') {\n    q.push({\n      contentType: 'SINGLE IMAGE',\n      postId: p.PostID,\n      body: { image_url: p.Visual_URL, caption: cap, access_token: tok },\n      hook: p.Hook,\n      aid\n    });\n\n  } else if (contentType === 'CAROUSEL') {\n    const kids = sd.slideIds[p.PostID] || [];\n    if (kids.length >= 2) {\n      q.push({\n        contentType: 'CAROUSEL',\n        postId: p.PostID,\n        body: { media_type: 'CAROUSEL', children: kids.join(','), caption: cap, access_token: tok },\n        topic: p.Topic,\n        slideCount: kids.length,\n        aid\n      });\n    } else {\n      q.push({ skip: true, postId: p.PostID, reason: `Only ${kids.length} slide IDs — need min 2` });\n    }\n\n  } else if (contentType === 'REEL') {\n    q.push({\n      contentType: 'REEL',\n      postId: p.PostID,\n      body: { media_type: 'REELS', video_url: p.Visual_URL, caption: cap, share_to_feed: true, access_token: tok },\n      hook: p.Hook,\n      aid\n    });\n\n  // ════ STORY ════ ✅\n  } else if (contentType === 'STORY') {\n    // ✅ Prefer Render_URL (S3 CDN) over Visual_URL (GitHub raw — Instagram can't fetch it)\n    const storyUrl = p.Render_URL || p.Visual_URL || '';\n\n    q.push({\n      contentType: 'STORY',\n      postId: p.PostID,\n      body: {\n        media_type:   'STORIES',\n        image_url:    storyUrl,       // ✅ S3 URL Instagram can actually fetch\n        access_token: tok\n        // ⚠️ No caption — Instagram Stories API does not support captions\n      },\n      storyType: p.StoryType || '',\n      aid\n    });\n  }\n});\n\nreturn q.length ? q.map(i => ({ json: i })) : [{ json: { empty: true } }];"
      },

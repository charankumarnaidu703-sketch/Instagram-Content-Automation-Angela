    {
      "parameters": {
        "jsCode": "const cfg = $('Read Config').first().json;\nconst cal = $input.all().map(i => i.json);\n\nconst now = new Date();\nconst soon = new Date(now.getTime() + 600000); // next 10 minutes\n\nconst sd = $getWorkflowStaticData('global');\nsd.slideIds = {};\nsd.pubResults = [];\n\n// Convert Google Drive share links to direct download\nfunction driveUrl(u) {\n  const m = (u || '').match(/\\/d\\/([^/]+)/);\n  return m ? 'https://drive.google.com/uc?export=download&id=' + m[1] : u;\n}\n\n// Instagram credentials\nconst tok = cfg.igAccessToken;\nconst aid = cfg.igAccountId;\n\nif (!tok || !aid) {\n  throw new Error('Instagram credentials missing in configuration');\n}\n\n// Filter posts that should be published\nconst due = cal.filter(p => {\n\n  if (p.Status !== 'approved') return false;\n\n  if (p.Visual_Created !== true && p.Visual_Created !== 'true') return false;\n\n  if (!p.Visual_URL) return false;\n\n  if (p.Already_Published === true || p.Already_Published === 'true') return false;\n\n  const type = (p.ContentType || '').toUpperCase();\n\n  if (!['SINGLE IMAGE', 'CAROUSEL', 'REEL', 'STORY'].includes(type)) return false;\n\n  // Scheduled publishing check\n  const dt = new Date(\n    p.ScheduledDate + 'T' + (p.ScheduledTime || '11:00') + ':00'\n  );\n\n  return dt <= soon;\n});\n\n// Stop workflow if nothing is ready\nif (!due.length) {\n  return [{\n    json: { hasPosts: false },\n    pairedItem: { item: 0 }\n  }];\n}\n\n// Prepare carousel slides\nconst slides = [];\n\ndue\n  .filter(p => (p.ContentType || '').toUpperCase() === 'CAROUSEL')\n  .forEach(p => {\n\n    const urlField =\n      (p.Slide_URLs && p.Slide_URLs.trim())\n        ? p.Slide_URLs\n        : p.Visual_URL;\n\n    (urlField || '')\n      .split(',')\n      .map(u => u.trim())\n      .filter(u => u)\n      .forEach((u, i, arr) => {\n\n        slides.push({\n          postId: p.PostID,\n          slideUrl: driveUrl(u),\n          slideNum: i + 1,\n          total: arr.length\n        });\n\n      });\n\n  });\n\n// Logging (useful in production debugging)\nconsole.log('Posts ready to publish:', due.length);\nconsole.log('Carousel slides detected:', slides.length);\n\nreturn [{\n  json: {\n    hasPosts: true,\n    due: due,\n    slides: slides,\n    tok: tok,\n    aid: aid\n  },\n  pairedItem: { item: 0 }\n}];"
      },
